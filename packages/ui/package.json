{
	"name": "@gykmi/ui",
	"version": "1.4.0",
	"type": "module",
	"license": "MIT",
	"scripts": {
		"build": "tsup && npx @tailwindcss/cli -i src/styles.css -o dist/styles.css --minify && cp src/theme.css dist/theme.css",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"validate": "publint && attw --pack --entrypoints . --ignore-rules cjs-resolves-to-esm no-resolution"
	},
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./css": {
			"style": "./dist/styles.css",
			"default": "./dist/styles.css"
		},
		"./theme": {
			"style": "./dist/theme.css",
			"default": "./dist/theme.css"
		}
	},
	"publishConfig": {
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js"
			},
			"./css": {
				"style": "./dist/styles.css",
				"default": "./dist/styles.css"
			},
			"./theme": {
				"style": "./dist/theme.css",
				"default": "./dist/theme.css"
			}
		}
	},
	"files": [
		"dist"
	],
	"peerDependencies": {
		"react": "^18 || ^19",
		"react-dom": "^18 || ^19"
	},
	"dependencies": {
		"@gykmi/tokens": "workspace:*",
		"@radix-ui/react-accordion": "^1.2.15",
		"@radix-ui/react-alert-dialog": "^1.1.18",
		"@radix-ui/react-aspect-ratio": "^1.1.11",
		"@radix-ui/react-avatar": "^1.2.1",
		"@radix-ui/react-checkbox": "^1.3.6",
		"@radix-ui/react-collapsible": "^1.1.15",
		"@radix-ui/react-context-menu": "^2.3.2",
		"@radix-ui/react-dialog": "^1.1.18",
		"@radix-ui/react-dropdown-menu": "^2.1.19",
		"@radix-ui/react-form": "^0.1.11",
		"@radix-ui/react-hover-card": "^1.1.18",
		"@radix-ui/react-label": "^2.1.11",
		"@radix-ui/react-menubar": "^1.1.19",
		"@radix-ui/react-navigation-menu": "^1.2.17",
		"@radix-ui/react-popover": "^1.1.18",
		"@radix-ui/react-progress": "^1.1.11",
		"@radix-ui/react-radio-group": "^1.4.2",
		"@radix-ui/react-scroll-area": "^1.2.13",
		"@radix-ui/react-select": "^2.3.2",
		"@radix-ui/react-separator": "^1.1.11",
		"@radix-ui/react-slider": "^1.4.2",
		"@radix-ui/react-slot": "^1.3.0",
		"@radix-ui/react-switch": "^1.3.2",
		"@radix-ui/react-tabs": "^1.1.16",
		"@radix-ui/react-toast": "^1.2.18",
		"@radix-ui/react-toggle": "^1.1.13",
		"@radix-ui/react-toggle-group": "^1.1.14",
		"@radix-ui/react-toolbar": "^1.1.14",
		"@radix-ui/react-tooltip": "^1.2.11",
		"@radix-ui/react-visually-hidden": "^1.2.7",
		"@visx/axis": "^4.0.0",
		"@visx/curve": "^4.0.0",
		"@visx/gradient": "^4.0.0",
		"@visx/grid": "^4.0.0",
		"@visx/group": "^4.0.0",
		"@visx/heatmap": "^4.0.0",
		"@visx/hierarchy": "^4.0.0",
		"@visx/legend": "^4.0.0",
		"@visx/pattern": "^4.0.0",
		"@visx/responsive": "^4.0.0",
		"@visx/scale": "^4.0.0",
		"@visx/shape": "^4.0.0",
		"@visx/stats": "^4.0.0",
		"@visx/text": "^4.0.0",
		"@visx/threshold": "^4.0.0",
		"@visx/tooltip": "^4.0.0",
		"clsx": "^2.1.1",
		"lucide-react": "^1.23.0",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@tailwindcss/cli": "^4.3.2",
		"@tailwindcss/vite": "^4.3.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"axe-core": "^4.12.1",
		"jsdom": "^29.1.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"shadcn": "^4.12.0",
		"tailwindcss": "^4.3.2",
		"tsup": "^8.5.1",
		"tw-animate-css": "^1.4.0",
		"vitest-axe": "^0.1.0"
	}
}

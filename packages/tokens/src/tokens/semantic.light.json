{
	"$description": "Semantic tokens — light theme. Every value references a primitive, never a raw value.",
	"surface": {
		"default": { "$value": "{color.neutral.0}", "$type": "color" },
		"raised": { "$value": "{color.neutral.50}", "$type": "color" },
		"overlay": { "$value": "{color.neutral.100}", "$type": "color" }
	},
	"text": {
		"default": { "$value": "{color.neutral.900}", "$type": "color" },
		"muted": { "$value": "{color.neutral.500}", "$type": "color" },
		"inverse": { "$value": "{color.neutral.0}", "$type": "color" }
	},
	"border": {
		"default": { "$value": "{color.neutral.200}", "$type": "color" },
		"strong": { "$value": "{color.neutral.400}", "$type": "color" }
	},
	"action": {
		"default": { "$value": "{color.blue.600}", "$type": "color" },
		"hover": { "$value": "{color.blue.700}", "$type": "color" },
		"active": { "$value": "{color.blue.800}", "$type": "color" },
		"text": { "$value": "{color.neutral.0}", "$type": "color" }
	},
	"danger": {
		"default": { "$value": "{color.red.600}", "$type": "color" },
		"subtle": { "$value": "{color.red.50}", "$type": "color" },
		"hover": { "$value": "{color.red.700}", "$type": "color" },
		"active": { "$value": "{color.red.800}", "$type": "color" },
		"text": { "$value": "{color.red.700}", "$type": "color" }
	},
	"success": {
		"default": { "$value": "{color.green.600}", "$type": "color" },
		"subtle": { "$value": "{color.green.50}", "$type": "color" },
		"text": { "$value": "{color.green.800}", "$type": "color" }
	},
	"warning": {
		"default": { "$value": "{color.amber.500}", "$type": "color" },
		"subtle": { "$value": "{color.amber.50}", "$type": "color" },
		"text": { "$value": "{color.amber.700}", "$type": "color" }
	},
	"focus": {
		"ring": { "$value": "{color.blue.500}", "$type": "color" }
	}
}

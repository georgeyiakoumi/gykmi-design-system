{
	"name": "@gykmi/tokens",
	"version": "1.0.0",
	"type": "module",
	"license": "MIT",
	"scripts": {
		"build": "node sd.config.js && node scripts/generate-index.js",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"validate": "publint && attw --pack --entrypoints . --ignore-rules cjs-resolves-to-esm no-resolution"
	},
	"exports": {
		".": {
			"types": "./dist/tokens.d.ts",
			"import": "./dist/tokens.js"
		},
		"./css": {
			"style": "./dist/tokens.css",
			"default": "./dist/tokens.css"
		}
	},
	"files": [
		"dist"
	],
	"devDependencies": {
		"style-dictionary": "^5.5.0"
	}
}

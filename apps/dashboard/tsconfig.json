{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "preserve",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./app/*"]
		},
		"ignoreDeprecations": "6.0",
		"allowJs": true,
		"noEmit": true,
		"incremental": true
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}

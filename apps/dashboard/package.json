{
	"name": "@gykmi/dashboard",
	"version": "0.0.3",
	"private": true,
	"scripts": {
		"dev": "next dev -p 3000",
		"dev:fresh": "lsof -ti :3000 | xargs kill -9 2>/dev/null; pnpm --filter @gykmi/tokens build && rm -rf .next && next dev -p 3000",
		"build": "next build",
		"start": "next start",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit",
		"test": "echo 'no unit tests — E2E via Playwright'",
		"e2e": "playwright test"
	},
	"dependencies": {
		"@gykmi/tokens": "workspace:*",
		"@gykmi/ui": "workspace:*",
		"next": "^15.5.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@tailwindcss/postcss": "^4.3.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"tailwindcss": "^4.3.2"
	}
}
